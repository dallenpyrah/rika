{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "categories": {
    "correctness": "error",
    "perf": "error",
    "suspicious": "error"
  },
  "overrides": [
    {
      "files": ["**/test/**"],
      "rules": {
        "no-await-in-loop": "off"
      }
    }
  ],
  "ignorePatterns": ["dist", "node_modules", ".turbo", "repos"]
}

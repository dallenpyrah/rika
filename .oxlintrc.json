{
  "$schema": "https://raw.githubusercontent.com/nicolo-ribaudo/oxc-project.github.io/refs/heads/json-schema/src/public/.oxlintrc.schema.json",
  "options": {
    "typeAware": true
  },
  "categories": {
    "correctness": "deny",
    "suspicious": "warn"
  },
  "rules": {
    "no-console": "error",
    "require-yield": "off",
    "typescript/no-floating-promises": "warn"
  },
  "overrides": [
    {
      "files": ["scripts/**", "packages/core/src/diagnostics.ts", "**/test/**", "**/*.test.ts"],
      "rules": {
        "no-console": "off"
      }
    }
  ],
  "ignorePatterns": [
    "**/node_modules/**",
    "**/dist/**",
    "**/build/**",
    "**/coverage/**",
    "**/.turbo/**",
    "**/.claude/**",
    "**/skills/motel-debug/**"
  ]
}

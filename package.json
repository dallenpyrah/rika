{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "rika",
  "description": "Local Effect-native durable coding agent CLI and TUI",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "workspaces": {
    "packages": [
      "packages/*",
      "apps/*"
    ],
    "catalog": {
      "@ast-grep/cli": "0.44.0",
      "@batonfx/core": "0.11.5",
      "@batonfx/mcp": "0.11.5",
      "@batonfx/providers": "0.11.5",
      "@batonfx/skills": "0.11.5",
      "@batonfx/test": "0.11.5",
      "@effect/platform-bun": "4.0.0-beta.98",
      "@effect/sql-mysql2": "4.0.0-beta.98",
      "@effect/sql-sqlite-bun": "4.0.0-beta.98",
      "@effect/tsgo": "0.21.0",
      "@effect/vitest": "4.0.0-beta.98",
      "@opentui/core": "0.4.3",
      "@opentui/core-darwin-arm64": "0.4.3",
      "@opentui/core-darwin-x64": "0.4.3",
      "@opentui/core-linux-arm64": "0.4.3",
      "@opentui/core-linux-arm64-musl": "0.4.3",
      "@opentui/core-linux-x64": "0.4.3",
      "@opentui/core-linux-x64-musl": "0.4.3",
      "@opentui/core-win32-arm64": "0.4.3",
      "@opentui/core-win32-x64": "0.4.3",
      "@opencode-ai/models": "0.0.18",
      "@pierre/diffs": "1.2.11",
      "@relayfx/sdk": "0.7.7",
      "@tsconfig/bun": "1.0.9",
      "@types/bun": "1.3.13",
      "@types/node": "24.12.2",
      "@types/prismjs": "1.26.6",
      "@vitest/coverage-v8": "4.0.16",
      "cli-spinners": "3.4.0",
      "effect": "4.0.0-beta.98",
      "marked": "17.0.1",
      "oxlint": "1.60.0",
      "oxlint-tsgolint": "0.21.0",
      "prettier": "3.6.2",
      "prismjs": "1.30.0",
      "turbo": "2.8.13",
      "typescript": "7.0.2",
      "vitest": "4.0.16"
    }
  },
  "overrides": {
    "@batonfx/core": "0.11.5",
    "@batonfx/providers": "0.11.5"
  },
  "scripts": {
    "ast-grep-check": "ast-grep scan --config sgconfig.yml --report-style short apps packages scripts test",
    "build": "bun turbo build",
    "check": "bun turbo run --continue build typecheck \"//#test-unit\" \"//#dependency-check\" \"//#diagnostics\" \"//#ast-grep-check\" \"//#format-check\" \"//#lint\"",
    "dependency-check": "bun run scripts/check-dependencies.ts",
    "dev": "bun --cwd apps/rika start",
    "diagnostics": "bun node_modules/@effect/tsgo/dist/effect-tsgo.js diagnostics --project ./tsconfig.json --format pretty --strict",
    "format": "prettier --write .",
    "format-check": "prettier --check .",
    "install-local": "bun run scripts/install-local.ts",
    "lint": "bun node_modules/oxlint/dist/cli.js apps packages scripts",
    "package": "bun run scripts/package.ts",
    "release-smoke": "bun run scripts/release-smoke.ts",
    "test": "bun turbo run \"//#test-unit\"",
    "test-proc": "bun --bun vitest run --project proc",
    "test-tui": "bun --bun vitest run --project tui",
    "test-unit": "bun --bun vitest run --project unit",
    "typecheck": "bun turbo run typecheck",
    "uninstall-local": "bun run scripts/uninstall-local.ts"
  },
  "prettier": {
    "printWidth": 120,
    "semi": false
  },
  "dependencies": {
    "@batonfx/core": "catalog:",
    "@batonfx/mcp": "catalog:",
    "@batonfx/providers": "catalog:",
    "@batonfx/skills": "catalog:",
    "@effect/platform-bun": "catalog:",
    "@effect/sql-sqlite-bun": "catalog:",
    "@relayfx/sdk": "catalog:",
    "effect": "catalog:"
  },
  "devDependencies": {
    "@ast-grep/cli": "catalog:",
    "@batonfx/test": "catalog:",
    "@effect/tsgo": "catalog:",
    "@effect/vitest": "catalog:",
    "@tsconfig/bun": "catalog:",
    "@types/bun": "catalog:",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "oxlint": "catalog:",
    "oxlint-tsgolint": "catalog:",
    "prettier": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}

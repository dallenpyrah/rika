{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "rika",
  "description": "Effect-native coding agent operating system inspired by Amp Code",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "scripts": {
    "build": "bun turbo build",
    "db:generate": "bun run --cwd packages/persistence db:generate",
    "db:migrate": "bun run --cwd packages/persistence db:migrate",
    "docs:check": "bun run scripts/check-docs.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "install:local": "bun run scripts/install-release.ts",
    "lint": "oxlint .",
    "orb:template": "bun run scripts/build-orb-template.ts",
    "orb:template:contract": "bun test scripts/orb-template.test.ts",
    "orb:template:smoke": "bun run scripts/orb-template-smoke.ts",
    "package": "bun run scripts/package-cli.ts",
    "package:smoke": "bun run scripts/package-smoke.ts",
    "parity:burst-compare": "bun run scripts/parity-burst-compare.ts",
    "parity:diff": "bun run scripts/parity-pixel-diff.ts",
    "parity:startup-burst-capture": "bun run scripts/parity-startup-burst-capture.ts",
    "parity:startup-measure": "bun run scripts/parity-startup-measure.ts",
    "update:local": "bun run scripts/install-release.ts",
    "test": "bun turbo test",
    "typecheck": "bun turbo typecheck",
    "web:dev": "bun run --cwd apps/web dev"
  },
  "workspaces": {
    "packages": [
      "packages/*",
      "apps/*"
    ],
    "catalog": {
      "@effect/ai-openai": "4.0.0-beta.90",
      "@effect/ai-anthropic": "4.0.0-beta.90",
      "@effect/opentelemetry": "4.0.0-beta.90",
      "@effect/platform-bun": "4.0.0-beta.90",
      "@effect/platform-node": "4.0.0-beta.90",
      "@effect/sql-sqlite-bun": "4.0.0-beta.90",
      "@opentelemetry/api": "1.9.1",
      "@opentelemetry/api-logs": "0.219.0",
      "@opentelemetry/exporter-logs-otlp-http": "0.219.0",
      "@opentelemetry/exporter-trace-otlp-http": "0.219.0",
      "@opentelemetry/resources": "2.8.0",
      "@opentelemetry/sdk-logs": "0.219.0",
      "@opentelemetry/sdk-metrics": "2.8.0",
      "@opentelemetry/sdk-trace-base": "2.8.0",
      "@opentelemetry/sdk-trace-node": "2.8.0",
      "@opentelemetry/semantic-conventions": "1.41.1",
      "@rivetkit/effect": "2.3.2",
      "@tsconfig/bun": "1.0.9",
      "@types/bun": "1.3.13",
      "@types/node": "24.12.2",
      "drizzle-kit": "1.0.0-rc.2",
      "drizzle-orm": "1.0.0-rc.2",
      "effect": "4.0.0-beta.90",
      "foldkit": "0.120.0",
      "oxlint": "1.60.0",
      "oxlint-tsgolint": "0.21.0",
      "prettier": "3.6.2",
      "rivetkit": "2.3.2",
      "turbo": "2.8.13",
      "typescript": "5.8.2",
      "vite": "8.1.2",
      "@foldkit/vite-plugin": "0.10.0"
    }
  },
  "devDependencies": {
    "@tsconfig/bun": "catalog:",
    "@types/bun": "catalog:",
    "@types/node": "catalog:",
    "oxlint": "catalog:",
    "oxlint-tsgolint": "catalog:",
    "prettier": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:"
  },
  "dependencies": {
    "@rika/core": "workspace:*",
    "@rika/persistence": "workspace:*",
    "effect": "catalog:"
  },
  "prettier": {
    "printWidth": 120,
    "semi": false
  }
}

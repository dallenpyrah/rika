{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "rika",
  "description": "Local Effect-native coding agent CLI on RivetKit actors",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "scripts": {
    "build": "bun turbo build",
    "db:generate": "bun run --cwd packages/persistence db:generate",
    "db:migrate": "bun run --cwd packages/persistence db:migrate",
    "docs:check": "bun run scripts/check-docs.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "install:local": "bun run scripts/install-release.ts",
    "lint": "oxlint . && ast-grep scan",
    "package": "bun run scripts/package-cli.ts",
    "package:smoke": "bun run scripts/package-smoke.ts",
    "update:local": "bun run scripts/install-release.ts",
    "test": "bun turbo test",
    "typecheck": "bun turbo typecheck"
  },
  "workspaces": {
    "packages": [
      "packages/*"
    ],
    "catalog": {
      "@ast-grep/cli": "0.44.0",
      "@effect/ai-openai": "4.0.0-beta.90",
      "@effect/ai-anthropic": "4.0.0-beta.90",
      "@effect/opentelemetry": "4.0.0-beta.90",
      "@effect/platform-node": "4.0.0-beta.90",
      "@effect/sql-sqlite-bun": "4.0.0-beta.90",
      "@opentelemetry/api": "1.9.1",
      "@opentelemetry/api-logs": "0.219.0",
      "@opentelemetry/exporter-logs-otlp-http": "0.219.0",
      "@opentelemetry/exporter-trace-otlp-http": "0.219.0",
      "@opentelemetry/resources": "2.8.0",
      "@opentelemetry/sdk-logs": "0.219.0",
      "@opentelemetry/sdk-metrics": "2.8.0",
      "@opentelemetry/sdk-trace-base": "2.8.0",
      "@opentelemetry/sdk-trace-node": "2.8.0",
      "@opentelemetry/semantic-conventions": "1.41.1",
      "@rivetkit/effect": "2.3.2",
      "@tsconfig/bun": "1.0.9",
      "@types/bun": "1.3.13",
      "@types/node": "24.12.2",
      "drizzle-kit": "1.0.0-rc.2",
      "drizzle-orm": "1.0.0-rc.2",
      "effect": "4.0.0-beta.90",
      "oxlint": "1.60.0",
      "oxlint-tsgolint": "0.21.0",
      "prettier": "3.6.2",
      "rivetkit": "2.3.2",
      "turbo": "2.8.13",
      "typescript": "5.8.2"
    }
  },
  "trustedDependencies": [
    "@ast-grep/cli"
  ],
  "devDependencies": {
    "@ast-grep/cli": "catalog:",
    "@tsconfig/bun": "catalog:",
    "@types/bun": "catalog:",
    "@types/node": "catalog:",
    "oxlint": "catalog:",
    "oxlint-tsgolint": "catalog:",
    "prettier": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:"
  },
  "dependencies": {
    "@rika/core": "workspace:*",
    "@rika/persistence": "workspace:*",
    "effect": "catalog:"
  },
  "prettier": {
    "printWidth": 120,
    "semi": false
  }
}

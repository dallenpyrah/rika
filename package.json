{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "rika",
  "description": "Local Effect-native durable coding agent CLI and TUI",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "workspaces": {
    "packages": [
      "packages/*",
      "apps/*"
    ],
    "catalog": {
      "@ast-grep/cli": "0.44.0",
      "@batonfx/core": "0.4.0",
      "@batonfx/mcp": "0.4.0",
      "@batonfx/providers": "0.4.0",
      "@batonfx/skills": "0.4.0",
      "@batonfx/test": "0.4.0",
      "@effect/ai-openrouter": "4.0.0-beta.93",
      "@effect/platform-bun": "4.0.0-beta.93",
      "@effect/sql-mysql2": "4.0.0-beta.93",
      "@effect/sql-sqlite-bun": "4.0.0-beta.93",
      "@effect/vitest": "4.0.0-beta.93",
      "@opentui/core": "0.4.2",
      "@opentui/core-darwin-arm64": "0.4.2",
      "@opentui/core-darwin-x64": "0.4.2",
      "@opentui/core-linux-arm64": "0.4.2",
      "@opentui/core-linux-arm64-musl": "0.4.2",
      "@opentui/core-linux-x64": "0.4.2",
      "@opentui/core-linux-x64-musl": "0.4.2",
      "@opentui/core-win32-arm64": "0.4.2",
      "@opentui/core-win32-x64": "0.4.2",
      "@pierre/diffs": "1.2.11",
      "@relayfx/sdk": "0.1.0",
      "@tsconfig/bun": "1.0.9",
      "@types/bun": "1.3.13",
      "@types/node": "24.12.2",
      "@types/prismjs": "1.26.6",
      "@vitest/coverage-v8": "4.0.16",
      "cli-spinners": "3.4.0",
      "effect": "4.0.0-beta.93",
      "marked": "17.0.1",
      "oxlint": "1.60.0",
      "oxlint-tsgolint": "0.21.0",
      "prettier": "3.6.2",
      "prismjs": "1.30.0",
      "turbo": "2.8.13",
      "typescript": "5.8.2",
      "vitest": "4.0.16"
    }
  },
  "scripts": {
    "build": "bun turbo build",
    "deps:check": "bun run scripts/check-dependencies.ts",
    "docs:check": "bun run scripts/check-docs.ts && bun run catalog:evidence",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "install:local": "bun run scripts/package.ts --target $(bun -e 'process.stdout.write(process.platform + \"-\" + process.arch)') && bun run scripts/install-local.ts",
    "install:local:existing": "bun run scripts/install-local.ts",
    "local:install": "bun run install:local",
    "lint": "oxlint apps packages scripts && ast-grep scan --config sgconfig.yml",
    "catalog:evidence": "bun run scripts/check-tool-catalog-evidence.ts",
    "package:build": "bun run scripts/package.ts",
    "package:construct:test": "bun test test/packaging/construction.test.ts",
    "package:smoke": "bun run scripts/package.ts --target $(bun -e 'process.stdout.write(process.platform + \"-\" + process.arch)') && bun run scripts/package-smoke.ts",
    "test": "bun turbo test",
    "test:agent-harness": "bun run --cwd packages/runtime test",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "bun run build && bun test test/e2e",
    "test:live": "RIKA_LIVE_MODEL_TEST=1 vitest run test/live --passWithNoTests --no-file-parallelism",
    "test:watch": "vitest",
    "typecheck": "bun turbo typecheck",
    "uninstall:local": "bun run scripts/uninstall-local.ts",
    "local:uninstall": "bun run uninstall:local",
    "upstream:link": "bun run scripts/upstream.ts link",
    "upstream:registry": "bun run scripts/upstream.ts registry",
    "upstream:status": "bun run scripts/upstream.ts status"
  },
  "prettier": {
    "printWidth": 120,
    "semi": false
  },
  "dependencies": {
    "@batonfx/core": "catalog:",
    "@batonfx/mcp": "catalog:",
    "@batonfx/providers": "catalog:",
    "@batonfx/skills": "catalog:",
    "@effect/ai-openrouter": "catalog:",
    "@effect/platform-bun": "catalog:",
    "@effect/sql-sqlite-bun": "catalog:",
    "@relayfx/sdk": "catalog:",
    "effect": "catalog:"
  },
  "devDependencies": {
    "@ast-grep/cli": "catalog:",
    "@batonfx/test": "catalog:",
    "@effect/vitest": "catalog:",
    "@tsconfig/bun": "catalog:",
    "@types/bun": "catalog:",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "oxlint": "catalog:",
    "oxlint-tsgolint": "catalog:",
    "prettier": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}

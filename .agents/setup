#!/usr/bin/env bash
set -euo pipefail

readonly bun_version="1.3.14"
export BUN_INSTALL="${BUN_INSTALL:-$HOME/.local}"
export PATH="$BUN_INSTALL/bin:$PATH"

echo "Preparing the Rika orb"

if ! command -v curl >/dev/null || ! command -v unzip >/dev/null; then
  sudo apt-get update
  sudo apt-get install -y curl unzip
fi

if ! command -v bun >/dev/null || [[ "$(bun --version)" != "$bun_version" ]]; then
  echo "Installing Bun $bun_version"
  curl --proto '=https' --tlsv1.2 -fsSL https://bun.sh/install | bash -s -- "bun-v$bun_version"
fi

echo "Installing frozen workspace dependencies"
CI=1 bun install --frozen-lockfile

find node_modules/.bun -path '*/@effect/tsgo-linux-*/lib/tsc' -exec chmod +x {} +

echo "Rika orb setup complete"

{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@rika/persistence",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "bun build ./src/index.ts --outdir dist --target bun --format esm",
    "db:generate": "drizzle-kit generate --config=drizzle.config.ts",
    "db:migrate": "env RIKA_DATA_DIR=../../.rika bun run src/migrate.ts",
    "lint": "bun --cwd ../.. oxlint packages/persistence/src packages/persistence/test packages/persistence/drizzle.config.ts",
    "test": "bun test --pass-with-no-tests",
    "typecheck": "bun tsc --noEmit"
  },
  "dependencies": {
    "@rika/core": "workspace:*",
    "@rika/schema": "workspace:*",
    "drizzle-orm": "catalog:",
    "effect": "catalog:",
    "postgres": "3.4.7"
  },
  "devDependencies": {
    "@electric-sql/pglite": "0.3.4",
    "@types/bun": "catalog:",
    "drizzle-kit": "catalog:",
    "pg-mem": "3.0.5",
    "typescript": "catalog:"
  }
}

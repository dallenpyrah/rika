{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@rika/app",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./interactive-feed-overflow": "./src/interactive-feed-overflow.ts",
    "./operation": "./src/operation.ts",
    "./operation-contract": "./src/operation-contract.ts",
    "./resident-service": "./src/resident-service.ts"
  },
  "scripts": {
    "build": "bun build ./src/index.ts --outdir dist --target bun --format esm",
    "lint": "bun --cwd ../.. node_modules/oxlint/dist/cli.js packages/app/src packages/app/test",
    "test": "bun --cwd ../.. --bun vitest run packages/app/test --passWithNoTests",
    "typecheck": "bun ../../node_modules/typescript/lib/tsc.js --noEmit"
  },
  "dependencies": {
    "@rika/config": "workspace:*",
    "@rika/extensions": "workspace:*",
    "@rika/persistence": "workspace:*",
    "@rika/runtime": "workspace:*",
    "@rika/tools": "workspace:*",
    "@rika/transcript": "workspace:*",
    "effect": "catalog:"
  },
  "devDependencies": {
    "@effect/vitest": "catalog:",
    "@types/bun": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}

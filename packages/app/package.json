{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@rika/app",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./operation": "./src/operation.ts"
  },
  "scripts": {
    "build": "bun build ./src/index.ts --outdir dist --target bun --format esm",
    "lint": "bun --cwd ../.. oxlint packages/app/src packages/app/test",
    "test": "bun --cwd ../.. vitest run packages/app/test --passWithNoTests",
    "typecheck": "bun tsc --noEmit"
  },
  "dependencies": {
    "@rika/config": "workspace:*",
    "@rika/extensions": "workspace:*",
    "@rika/persistence": "workspace:*",
    "@rika/runtime": "workspace:*",
    "@rika/tools": "workspace:*",
    "effect": "catalog:"
  },
  "devDependencies": {
    "@effect/vitest": "catalog:",
    "@types/bun": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}

{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@rika/tui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./adapter": "./src/adapter.ts"
  },
  "scripts": {
    "build": "bun build ./src/index.ts ./src/adapter.ts --outdir dist --target bun --format esm --external effect --external '@opentui/core' --external '@opentui/core/*'",
    "lint": "bun --cwd ../.. node_modules/oxlint/dist/cli.js packages/tui/src packages/tui/test",
    "typecheck": "bun ../../node_modules/typescript/lib/tsc.js --noEmit"
  },
  "dependencies": {
    "@opentui/core": "catalog:",
    "@pierre/diffs": "catalog:",
    "@rika/transcript": "workspace:*",
    "cli-spinners": "catalog:",
    "effect": "catalog:",
    "marked": "catalog:",
    "prismjs": "catalog:",
    "string-width": "catalog:"
  },
  "devDependencies": {
    "@effect/vitest": "catalog:",
    "@types/bun": "catalog:",
    "@types/prismjs": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}

{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@rika/tui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./keymap": "./src/keymap.ts"
  },
  "scripts": {
    "build": "bun build ./src/index.ts --outdir dist --target bun --format esm --external @opentui/core-darwin-arm64 --external @opentui/core-darwin-x64 --external @opentui/core-linux-arm64 --external @opentui/core-linux-arm64-musl --external @opentui/core-linux-x64 --external @opentui/core-linux-x64-musl --external @opentui/core-win32-arm64 --external @opentui/core-win32-x64",
    "lint": "bun --cwd ../.. oxlint packages/tui/src packages/tui/test",
    "test": "bun test --pass-with-no-tests",
    "typecheck": "bun tsc --noEmit"
  },
  "dependencies": {
    "@rika/core": "workspace:*",
    "@rika/llm": "workspace:*",
    "@rika/schema": "workspace:*",
    "@opentui/core": "0.4.2",
    "@pierre/diffs": "1.2.11",
    "effect": "catalog:"
  },
  "devDependencies": {
    "@types/bun": "catalog:",
    "typescript": "catalog:"
  }
}

{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@rika/cli",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "rika": "./src/main.ts"
  },
  "exports": {
    ".": "./src/index.ts",
    "./backend-endpoint": "./src/backend-endpoint.ts",
    "./local-backend": "./src/local-backend.ts"
  },
  "scripts": {
    "build": "bun build ./src/main.ts --outdir dist --target bun --format esm --external @opentui/core-darwin-arm64 --external @opentui/core-darwin-x64 --external @opentui/core-linux-arm64 --external @opentui/core-linux-arm64-musl --external @opentui/core-linux-x64 --external @opentui/core-linux-x64-musl --external @opentui/core-win32-arm64 --external @opentui/core-win32-x64",
    "lint": "bun --cwd ../.. oxlint packages/cli/src packages/cli/test",
    "test": "bun test --pass-with-no-tests",
    "typecheck": "bun tsc --noEmit"
  },
  "dependencies": {
    "@effect/platform-node": "catalog:",
    "@rika/agent": "workspace:*",
    "@rika/core": "workspace:*",
    "@rika/ide": "workspace:*",
    "@rika/llm": "workspace:*",
    "@rika/orb": "workspace:*",
    "@rika/persistence": "workspace:*",
    "@rika/plugin": "workspace:*",
    "@rika/rivet-host": "workspace:*",
    "@rika/schema": "workspace:*",
    "@rika/sdk": "workspace:*",
    "@rika/server": "workspace:*",
    "@rika/tools": "workspace:*",
    "@rika/tui": "workspace:*",
    "effect": "catalog:"
  },
  "devDependencies": {
    "@types/bun": "catalog:",
    "typescript": "catalog:"
  }
}

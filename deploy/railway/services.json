{
  "project": "rika",
  "workspace": "dallenpyrah",
  "repository": "dallenpyrah/rika",
  "environments": {
    "staging": {
      "branch": "main",
      "isBaseForPrEnvironments": true
    },
    "production": {
      "branch": "release",
      "isBaseForPrEnvironments": false
    },
    "pr": {
      "namePattern": "rika-pr-<n>",
      "inheritsFrom": "staging"
    }
  },
  "services": [
    {
      "name": "rika-postgres",
      "kind": "postgres-plugin"
    },
    {
      "name": "rika-rivet-engine",
      "kind": "app",
      "startCommand": "bun packages/rivet-host/src/main.ts",
      "env": {
        "RIVET_RUN_ENGINE": "1"
      },
      "healthcheckPath": "/metadata",
      "restartPolicyType": "ON_FAILURE",
      "storageBackend": "filesystem",
      "storageBackendNotes": "Prefer FoundationDB for multi-node; Postgres engine storage is experimental"
    },
    {
      "name": "rika-actor-runner",
      "kind": "app",
      "startCommand": "bun packages/rivet-host/src/main.ts",
      "healthcheckPath": "/health",
      "restartPolicyType": "ON_FAILURE"
    },
    {
      "name": "rika-edge",
      "kind": "app",
      "startCommand": "bun packages/cli/src/main.ts server --host 0.0.0.0 --port $PORT",
      "preDeployCommand": "bun run db:migrate",
      "healthcheckPath": "/health",
      "restartPolicyType": "ON_FAILURE",
      "idleTimeoutDisabled": true
    },
    {
      "name": "rika-web",
      "kind": "app",
      "startCommand": "bun packages/cli/src/main.ts web-proxy --host 0.0.0.0 --port $PORT",
      "buildCommand": "bun run --cwd apps/web build",
      "healthcheckPath": "/",
      "restartPolicyType": "ON_FAILURE"
    }
  ],
  "envVarFamilies": [
    "RIKA_DATABASE_URL",
    "RIKA_API_KEY",
    "E2B_API_KEY",
    "RIKA_ORB_TEMPLATE",
    "RIKA_SERVER_TOKEN",
    "RIKA_RIVET_HOST",
    "RIKA_RIVET_ENDPOINT",
    "RIKA_RIVET_TOKEN",
    "RIKA_RIVET_NAMESPACE"
  ],
  "websocketResume": {
    "required": true,
    "mechanism": "GetEvents after_sequence catch-up after reconnect",
    "railwayPublicNetworkingDurationLimitMinutes": 15
  }
}

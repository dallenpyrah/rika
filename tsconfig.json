{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@tsconfig/bun/tsconfig.json",
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "exactOptionalPropertyTypes": true,
    "noEmit": true,
    "noUncheckedIndexedAccess": true,
    "strict": true,
    "types": ["bun"]
  },
  "exclude": ["node_modules", "dist", "build", "coverage", ".turbo"]
}
